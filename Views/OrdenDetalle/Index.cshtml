@model IEnumerable<Web_Inventario.Models.OrdenDetalle>

@{
    ViewData["Title"] = "Detalles de Órdenes";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Agregar Detalle</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Orden</th>
            <th>Producto</th>
            <th>Cantidad</th>
            <th>Precio Unitario</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.OrdenCompraId</td>
                <td>@item.Producto?.Nombre</td>
                <td>@item.Cantidad</td>
                <td>@item.PrecioUnitario</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.OrdenDetalleId" class="btn btn-warning btn-sm">Editar</a> |
                    <a asp-action="Delete" asp-route-id="@item.OrdenDetalleId" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
